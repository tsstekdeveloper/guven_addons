<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="guven_mukellef_update_wizard_view_form" model="ir.ui.view">
            <field name="name">guven.mukellef.update.wizard.form</field>
            <field name="model">guven.mukellef.update.wizard</field>
            <field name="arch" type="xml">
                <form string="Mükellef Kaydı Güncelleme">
                    <!-- Draft state: onay mesajı -->
                    <div invisible="state != 'draft'" style="padding:8px 4px">
                        <h3 style="margin-top:0">Mükellef Kayıtları Güncellenecek</h3>
                        <p>
                            Bu işlem aşağıdaki adımları gerçekleştirecektir:
                        </p>
                        <ol>
                            <li>
                                <strong>GİB Fatura tablosundan</strong> sender/receiver
                                VKN/TCKN kimlikleri toplanacak. Mevcut mükelleflerin
                                ünvanları güncellenecek, olmayanlar
                                <strong>kaynak=GİB</strong> olarak eklenecek.
                            </li>
                            <li>
                                <strong>Logo Fatura tablosundan</strong> VKN/TCKN
                                kimlikleri toplanacak. Mükellef tablosunda olmayan
                                kayıtlar <strong>kaynak=LOGO</strong> ve
                                <strong>"LOGO-MUK-XXXXXXX Nolu LOGO mükellefi"</strong>
                                ünvanıyla eklenecek.
                            </li>
                        </ol>
                        <p>
                            İşlem birkaç dakika sürebilir. Devam etmek istiyor musunuz?
                        </p>
                    </div>

                    <!-- Done state: rapor -->
                    <div invisible="state != 'done'">
                        <field name="report_html" nolabel="1"/>
                    </div>

                    <field name="state" invisible="1"/>

                    <footer>
                        <button string="Devam Et"
                                name="action_execute"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'draft'"
                                confirm="Mükellef kayıtları güncellenecek. Emin misiniz?"/>
                        <button string="İptal"
                                special="cancel"
                                class="btn-secondary"
                                invisible="state != 'draft'"/>
                        <button string="Kapat"
                                name="action_close"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'done'"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_guven_mukellef_update_wizard"
                model="ir.actions.act_window">
            <field name="name">Mükellef Kaydı Güncelleme</field>
            <field name="res_model">guven.mukellef.update.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'dialog_size': 'large'}</field>
        </record>

    </data>
</odoo>
