<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- SEARCH VIEW                                                  -->
        <!-- ============================================================ -->
        <record id="view_guven_gib_mukellef_search" model="ir.ui.view">
            <field name="name">guven.gib.mukellef.search</field>
            <field name="model">guven.gib.mukellef</field>
            <field name="arch" type="xml">
                <search string="Mükellef Arama">
                    <field name="identifier" string="VKN/TCKN"/>
                    <field name="title" string="Ünvan"/>
                    <separator/>
                    <filter name="filter_izibiz" string="izibiz"
                            domain="[('kaynak', '=', 'izibiz')]"/>
                    <filter name="filter_gib" string="GİB"
                            domain="[('kaynak', '=', 'gib')]"/>
                    <filter name="filter_logo" string="LOGO"
                            domain="[('kaynak', '=', 'logo')]"/>
                    <group>
                        <filter name="group_kaynak" string="Kaynak"
                                context="{'group_by': 'kaynak'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- LIST VIEW (read-only)                                        -->
        <!-- ============================================================ -->
        <record id="view_guven_gib_mukellef_list" model="ir.ui.view">
            <field name="name">guven.gib.mukellef.list</field>
            <field name="model">guven.gib.mukellef</field>
            <field name="arch" type="xml">
                <list create="0" edit="0" delete="0"
                      default_order="title">
                    <field name="identifier" string="VKN/TCKN"/>
                    <field name="title" string="Ünvan"/>
                    <field name="kaynak" string="Kaynak"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- FORM VIEW (read-only)                                        -->
        <!-- ============================================================ -->
        <record id="view_guven_gib_mukellef_form" model="ir.ui.view">
            <field name="name">guven.gib.mukellef.form</field>
            <field name="model">guven.gib.mukellef</field>
            <field name="arch" type="xml">
                <form create="0" edit="0" delete="0">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="title" readonly="1"
                                       placeholder="Ünvan"/>
                            </h1>
                            <h3>
                                <field name="identifier" readonly="1"/>
                            </h3>
                        </div>
                        <group>
                            <field name="identifier" readonly="1"/>
                            <field name="title" readonly="1"/>
                            <field name="kaynak" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- ACTION — Mükellef Kayıtları listesi                          -->
        <!-- ============================================================ -->
        <record id="action_guven_gib_mukellef" model="ir.actions.act_window">
            <field name="name">Mükellef Kayıtları</field>
            <field name="res_model">guven.gib.mukellef</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_guven_gib_mukellef_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Henüz mükellef kaydı yok.
                </p>
                <p>
                    Mükellef kayıtları izibiz, GİB veya LOGO kaynaklarından
                    beslenir.
                </p>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- PLACEHOLDER ACTION — Mükellef Kaydı Güncelleme (yakında)     -->
        <!-- ============================================================ -->
        <record id="action_guven_mukellef_sync_placeholder"
                model="ir.actions.act_window">
            <field name="name">Mükellef Kaydı Güncelleme</field>
            <field name="res_model">guven.gib.mukellef</field>
            <field name="view_mode">list</field>
            <field name="domain">[('id', '=', 0)]</field>
            <field name="search_view_id" ref="view_guven_gib_mukellef_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Bu özellik yakında eklenecek
                </p>
                <p>
                    Mükellef kayıtları artık kendi sistemimizden beslenecek.
                    Güncelleme mekanizması sonraki sürümde tanımlanacak.
                </p>
            </field>
        </record>

    </data>
</odoo>
